# ── Required ───────────────────────────────────────────────────────────────────
# Anthropic API key — used by all three nodes (planner, executor, validator)
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: model overrides ──────────────────────────────────────────────────
# Override the default models used by each node.
# Defaults are set in PEVConfig — change them in code or via env vars.
#
# PEV_PLANNER_MODEL=claude-haiku-4-5-20251001
# PEV_EXECUTOR_MODEL=claude-sonnet-4-6
# PEV_VALIDATOR_MODEL=claude-haiku-4-5-20251001

# ── Optional: LangSmith tracing ────────────────────────────────────────────────
# Uncomment to enable LangSmith observability for all LangGraph runs.
# Install the tracing extra first: uv add "pev-langgraph[tracing]"
#
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=pev-langgraph
#
# For per-run tags and metadata, use PEVConfig.run_config():
#   cfg = PEVConfig(run_name="my-agent", run_tags=["prod"], run_metadata={"user": "u-1"})
#   result = graph.invoke(state, config=cfg.run_config())
